{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/security_report.schema.json",
  "title": "AEGIS Security Report",
  "type": "object",
  "required": [
    "report_id",
    "generated_at",
    "testbed_config",
    "total_attacks",
    "total_successful",
    "attack_success_rate",
    "results_by_owasp",
    "findings",
    "recommendations",
    "run_errors",
    "probe_results"
  ],
  "additionalProperties": true,
  "properties": {
    "report_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "testbed_config": { "type": "object" },
    "total_attacks": { "type": "integer", "minimum": 0 },
    "total_successful": { "type": "integer", "minimum": 0 },
    "attack_success_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "defense_comparison": {
      "type": ["object", "null"]
    },
    "results_by_owasp": {
      "type": "object",
      "patternProperties": {
        "^[A-Z0-9-]+$": { "$ref": "#/$defs/owaspCategoryResult" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "run_errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/errorRecord" }
    },
    "probe_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/probeResult" }
    },
    "methodology": {
      "type": ["object", "null"],
      "properties": {
        "negative_controls": { "$ref": "#/$defs/negativeControlSummary" }
      },
      "additionalProperties": true
    },
    "defense_matrix": {
      "type": ["object", "null"]
    }
  },
  "$defs": {
    "errorRecord": {
      "type": "object",
      "required": ["module", "phase", "status", "error", "traceback"],
      "properties": {
        "module": { "type": "string" },
        "phase": { "type": "string" },
        "status": { "type": "string", "enum": ["error"] },
        "error": { "type": "string" },
        "traceback": { "type": "string" }
      },
      "additionalProperties": true
    },
    "probeResult": {
      "type": "object",
      "required": [
        "probe_id",
        "module",
        "owasp_id",
        "owasp_category",
        "passed",
        "success",
        "score",
        "score_method",
        "response_snippet"
      ],
      "properties": {
        "probe_id": { "type": "string" },
        "module": { "type": "string" },
        "owasp_id": { "type": "string" },
        "owasp_category": { "type": "string" },
        "passed": { "type": "boolean" },
        "success": { "type": "boolean" },
        "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "score_method": { "type": "string" },
        "response_snippet": { "type": "string" },
        "attack_family": { "type": "string" },
        "technique_tag": { "type": ["string", "null"] },
        "expected_signal": { "type": ["string", "null"] },
        "is_negative_control": { "type": "boolean" },
        "retrieval_trace_count": { "type": "integer", "minimum": 0 },
        "retrieval_included_count": { "type": "integer", "minimum": 0 },
        "retrieval_poisoned_included_count": { "type": "integer", "minimum": 0 },
        "phase5_summary": { "type": "string" },
        "payload_language": { "type": "string" },
        "cloaking_differential": { "type": "object" },
        "identity_chain": { "type": "object" },
        "manipulation_vector": { "type": ["string", "null"] },
        "message_provenance": { "type": ["object", "null"] },
        "approval_summary_mismatch": { "type": "object" },
        "trust_signal": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "negativeControlSummary": {
      "type": "object",
      "required": ["total", "false_positives", "false_positive_rate"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "false_positives": { "type": "integer", "minimum": 0 },
        "false_positive_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "by_module": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/moduleNegativeControlSummary" }
        }
      },
      "additionalProperties": true
    },
    "moduleNegativeControlSummary": {
      "type": "object",
      "required": ["total", "false_positives", "false_positive_rate"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "false_positives": { "type": "integer", "minimum": 0 },
        "false_positive_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "additionalProperties": false
    },
    "owaspMapping": {
      "type": "object",
      "required": ["owasp_id", "owasp_name", "mitre_atlas_id"],
      "properties": {
        "owasp_id": { "type": "string" },
        "owasp_name": { "type": "string" },
        "mitre_atlas_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "title",
        "owasp_id",
        "owasp_category",
        "severity",
        "description",
        "evidence",
        "recommendation",
        "delta_vs_baseline",
        "owasp_mapping"
      ],
      "properties": {
        "title": { "type": "string" },
        "owasp_id": { "type": "string" },
        "owasp_category": { "type": "string" },
        "atlas_technique": { "type": ["string", "null"] },
        "mitre_atlas_id": { "type": ["string", "null"] },
        "severity": {
          "type": "string",
          "enum": ["informational", "low", "medium", "high", "critical"]
        },
        "description": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommendation": { "type": "string" },
        "delta_vs_baseline": { "type": ["number", "null"] },
        "owasp_mapping": { "$ref": "#/$defs/owaspMapping" }
      },
      "additionalProperties": true
    },
    "owaspCategoryResult": {
      "type": "object",
      "required": [
        "owasp_id",
        "category_name",
        "total_attacks",
        "successful_attacks",
        "attack_success_rate",
        "findings"
      ],
      "properties": {
        "owasp_id": { "type": "string" },
        "category_name": { "type": "string" },
        "total_attacks": { "type": "integer", "minimum": 0 },
        "successful_attacks": { "type": "integer", "minimum": 0 },
        "attack_success_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        }
      },
      "additionalProperties": false
    }
  }
}
