# Docker Compose defaults for AEGIS.
# Copy this file to ".env" and adjust values for your environment.
# Direct Linux/WSL runs read process environment variables. Export values in
# your shell or CI secret store unless you explicitly source this file.

# AEGIS runtime
AEGIS_CONFIG_PATH=/app/aegis/config.local_single_qwen.yaml
# Valid values: blank (use config), auto, ollama, huggingface, offline,
# openai_compat, anthropic, hf_inference
AEGIS_PROVIDER_MODE=
# Optional model overrides. Set AEGIS_TARGET_MODEL to use one model for the
# target, fallback, and judge; set the others only when you want them different.
AEGIS_TARGET_MODEL=
AEGIS_FALLBACK_MODEL=
AEGIS_JUDGE_MODEL=

# Dashboard exposure
AEGIS_DASHBOARD_BIND_ADDRESS=127.0.0.1
AEGIS_DASHBOARD_PORT=8501

# Local Ollama model service. Space-separate multiple models if needed.
# Keep this aligned with AEGIS_TARGET_MODEL / AEGIS_JUDGE_MODEL.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODELS=

# Optional external provider secrets. Keep real values in your shell, local
# .env, or hosting platform secret store; never commit them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=
PROVIDER_API_KEY=
ACME_LLM_API_KEY=
